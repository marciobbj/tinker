<resources>
    <!-- Base application theme -->
    <style name="Theme.PdfReader" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorPrimaryContainer">@color/purple_100</item>
        <item name="colorOnPrimaryContainer">@color/purple_900</item>
        <item name="android:colorBackground">@android:color/white</item>
        <item name="colorSurface">@android:color/white</item>
        <item name="colorOnSurface">@android:color/black</item>
        <item name="colorOnSurfaceVariant">@android:color/darker_gray</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.PdfReader.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/purple_300</item>
        <item name="colorOnPrimary">@android:color/black</item>
        <item name="colorPrimaryContainer">@color/purple_700</item>
        <item name="colorOnPrimaryContainer">@color/purple_100</item>
        <item name="android:colorBackground">@android:color/black</item>
        <item name="colorSurface">#1C1C1C</item>
        <item name="colorOnSurface">@android:color/white</item>
        <item name="colorOnSurfaceVariant">#AAAAAA</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.PdfReader.NoActionBar" parent="Theme.PdfReader">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <style name="Theme.PdfReader.Dark.NoActionBar" parent="Theme.PdfReader.Dark">
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
